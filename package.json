{
    "name": "pulsarjs-workspace",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm --filter api dev",
        "build": "pnpm --recursive run build",
        "test": "pnpm --recursive --if-present run test",
        "typecheck": "pnpm --recursive --if-present run typecheck",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,ts,tsx}": [
            "pnpm exec eslint --fix"
        ]
    },
    "devDependencies": {
        "eslint": "^9.39.3",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "typescript-eslint": "^8.56.0",
        "wrangler": "^4.67.0"
    },
    "pnpm": {
        "overrides": {
            "esbuild": "^0.25.0",
            "minimatch": "^10.2.1"
        }
    }
}