{
    "name": "pulsarjs-workspace",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm --recursive run build",
        "test": "pnpm --recursive --if-present run test",
        "typecheck": "pnpm --recursive --if-present run typecheck",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,ts,tsx}": [
            "pnpm exec eslint --fix"
        ]
    },
    "devDependencies": {
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "typescript-eslint": "^8.58.0"
    },
    "pnpm": {
        "overrides": {
            "ajv": ">=8.18.0",
            "esbuild": "^0.25.0",
            "minimatch": "^10.2.1",
            "flatted": ">=3.4.2",
            "undici": ">=7.24.0"
        }
    }
}