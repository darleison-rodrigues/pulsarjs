{
  "name": "pulsarjs-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev -c ../wrangler.json",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy -c ../wrangler.json",
    "db:migrate": "wrangler d1 migrations apply DB --remote -c ../wrangler.json",
    "db:migrate:local": "wrangler d1 migrations apply DB --local -c ../wrangler.json",
    "test": "vitest run"
  },
  "dependencies": {
    "esbuild": "0.27.3",
    "hono": "^4.0.0",
    "ipaddr.js": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.12",
    "@cloudflare/workers-types": "^4.20260205.0",
    "@types/node": "^20.19.31",
    "@vitest/coverage-istanbul": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/runner": "^2.1.8",
    "@vitest/snapshot": "^2.1.8",
    "@vitest/utils": "^2.1.8",
    "eslint": "^9.0.0",
    "miniflare": "^4.20260212.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.9",
    "wrangler": "^4.63.0"
  },
  "overrides": {
    "esbuild": "$esbuild"
  }
}